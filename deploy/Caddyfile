# Caddy reverse proxy for Glitch. Auto-provisions TLS via Let's Encrypt.
# Requires: ports 80 + 443 open, and DNS A/AAAA for agent.mattharris.tech -> this host.
#
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

agent.mattharris.tech {
	# The app binds 127.0.0.1:8080 (not public); Caddy terminates TLS + proxies.
	# SSE (chat streaming) works through Caddy's default streaming proxy.
	reverse_proxy 127.0.0.1:8080
}
